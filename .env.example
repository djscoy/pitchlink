# ============================================================
# PitchLink Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# --- Chrome Extension ---
EXTENSION_ID=your-extension-id-after-first-load

# --- API Server ---
PORT=3001
NODE_ENV=development

# --- GCP Pub/Sub (Phase 2: Reply Detection) ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_PUBSUB_TOPIC=pitchlink-gmail-notifications
GCP_PUBSUB_SUBSCRIPTION=pitchlink-gmail-sub
GMAIL_WEBHOOK_URL=https://your-api-domain.com/api/gmail/webhook

# --- Anthropic Claude API (Phase 3+: IIE & AI Compose) ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Contact Enrichment & Discovery ---
# EXPLORIUM_API_KEY=          # Vibe Prospecting (primary provider)
# HUNTER_API_KEY=
# APOLLO_API_KEY=
# DATAFORSEO_LOGIN=
# DATAFORSEO_PASSWORD=

# --- Email Sending (Phase 4: Sequences) ---
# SENDGRID_API_KEY=

# --- CORS (Production) ---
# CORS_ALLOWED_ORIGINS=          # Comma-separated origins for web frontends (e.g., https://app.pitchlink.io)

# --- Analytics & Monitoring (Phase 6) ---
# POSTHOG_API_KEY=
# SENTRY_DSN=
