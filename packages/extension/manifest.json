{
  "manifest_version": 3,
  "name": "PitchLink",
  "description": "Gmail-native outreach CRM — manage your pipeline, contacts, and sequences without leaving your inbox.",
  "version": "0.1.0",
  "permissions": [
    "identity",
    "storage",
    "activeTab",
    "alarms",
    "scripting"
  ],
  "oauth2": {
    "client_id": "604601221757-imn4odveb1qshfs1vf3anrvoqfutcsko.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.readonly",
      "https://www.googleapis.com/auth/gmail.send",
      "https://www.googleapis.com/auth/gmail.compose",
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["pitchlink.css"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://www.googleapis.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["pageWorld.js"],
      "matches": ["https://mail.google.com/*"]
    }
  ]
}
